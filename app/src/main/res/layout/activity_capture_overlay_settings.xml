<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/ptSurface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/ptText"
        app:title="@string/settings_cell_capture_overlay"
        app:titleTextColor="?attr/ptText" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/pt_section_h_padding"
            android:paddingTop="4dp"
            android:paddingBottom="20dp">

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- CAPTURE DISPLAY (conditional: multi-display)          -->
            <!-- ══════════════════════════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/captureDisplaySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <include layout="@layout/settings_group_header"
                    android:id="@+id/headerCaptureDisplay" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/ptCard"
                    app:cardCornerRadius="@dimen/pt_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/ptDivider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/llDisplayOptions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_word_tatoeba_attribution"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:text="@string/settings_capture_display_footer"
                            android:textColor="?attr/ptTextHint"
                            android:textSize="11sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- IMAGE-TO-TEXT (OCR)                                   -->
            <!-- ══════════════════════════════════════════════════════ -->
            <!-- Header + card visibility are toggled in
                 CaptureOverlaySettingsActivity.setupOcrSection (hidden when the
                 current source language has no engine choice beyond the ML Kit
                 floor). One row per available OCR engine is inflated into
                 containerOcrLanguages. -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerOcr" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOcr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/containerOcrLanguages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_word_tatoeba_attribution"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/settings_ocr_footer"
                        android:textColor="?attr/ptTextHint"
                        android:textSize="11sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- AUTO-TRANSLATE                                        -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerAutoTranslate" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAutoTranslate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Enhanced auto-translate. Off: switch + the "More
                         responsive…" pitch — tapping the row shows the
                         accessibility-required alert. On: checkmark + "Enabled",
                         row becomes non-clickable. Driven by
                         CaptureOverlaySettingsActivity.refreshEnhancedAutoTranslateRow
                         against PlayTranslateAccessibilityService.isEnabled. -->
                    <LinearLayout
                        android:id="@+id/rowEnhancedAutoTranslate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/pt_row_min_height"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/pt_row_h_padding"
                        android:paddingVertical="9dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/enhanced_auto_translate_title"
                                style="@style/Text.PT.RowTitle" />

                            <TextView
                                android:id="@+id/tvEnhancedAutoTranslateSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                style="@style/Text.PT.RowSubtitle" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchEnhancedAutoTranslate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false"
                            app:materialThemeOverlay="@style/Widget.PlayTranslate.MaterialSwitch" />

                        <ImageView
                            android:id="@+id/checkEnhancedAutoTranslate"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check"
                            android:importantForAccessibility="no"
                            android:visibility="gone"
                            app:tint="?attr/ptAccent" />

                    </LinearLayout>

                    <View
                        android:id="@+id/dividerEnhancedAutoTranslate"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/pt_row_h_padding"
                        android:background="?attr/ptDivider" />

                    <!-- Overlay mode section (conditional: only when language has hint text) -->
                    <LinearLayout
                        android:id="@+id/overlayModeSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/pt_row_h_padding"
                        android:paddingVertical="@dimen/pt_row_v_padding"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_overlay_mode_title"
                            style="@style/Text.PT.RowTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/settings_overlay_mode_subtitle"
                            style="@style/Text.PT.RowSubtitle" />

                        <FrameLayout
                            android:id="@+id/overlayModeToggleContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/dividerOverlayMode"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/pt_row_h_padding"
                        android:background="?attr/ptDivider"
                        android:visibility="gone" />

                    <!-- Hide overlays toggle (conditional: multi-screen only) -->
                    <include layout="@layout/settings_row_switch"
                        android:id="@+id/rowHideOverlays"
                        android:visibility="gone" />

                    <View
                        android:id="@+id/dividerHideOverlays"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/pt_row_h_padding"
                        android:background="?attr/ptDivider" />

                    <!-- Capture interval (value-row style) -->
                    <LinearLayout
                        android:id="@+id/rowCaptureInterval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/pt_row_min_height"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/pt_row_h_padding"
                        android:paddingVertical="@dimen/pt_row_v_padding"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:labelFor="@+id/etCaptureInterval"
                                android:text="@string/settings_capture_interval_title"
                                style="@style/Text.PT.RowTitle" />

                            <TextView
                                android:id="@+id/tvCaptureIntervalHint"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                style="@style/Text.PT.RowSubtitle" />
                        </LinearLayout>

                        <EditText
                            android:id="@+id/etCaptureInterval"
                            android:layout_width="48dp"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:textSize="13sp"
                            android:textColor="?attr/ptTextMuted"
                            android:background="@android:color/transparent"
                            android:inputType="numberDecimal"
                            android:maxLength="3"
                            android:imeOptions="actionDone"
                            android:importantForAutofill="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_capture_interval_seconds_suffix"
                            android:layout_marginEnd="4dp"
                            style="@style/Text.PT.RowValue" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="?attr/ptTextMuted"
                            android:importantForAccessibility="no" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
