<?xml version="1.0" encoding="utf-8"?>
<!-- Drag-lookup popup list-item row. android:background is the ripple
     state-list, not a static fill — see settings_row_hotkey for the
     full Overdraw note. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/pt_row_min_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="@dimen/pt_row_h_padding"
    android:paddingVertical="@dimen/pt_row_v_padding"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    tools:ignore="Overdraw">

    <!-- Word (headword) -->
    <TextView
        android:id="@+id/tvItemWord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/ptTextLink"
        android:textSize="18sp"
        android:textStyle="bold"
        android:minWidth="80dp"
        android:paddingStart="0dp"
        android:paddingEnd="12dp" />

    <!-- Reading + stars + meaning stacked -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Reading + badges (Common, stars, and the runtime-added "in Anki"
             deck pill). FlowLayout so a long deck name wraps to a new line. -->
        <com.playtranslate.ui.FlowLayout
            android:id="@+id/itemBadgeFlow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvItemReading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/ptTextHint"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvItemCommon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_anki_meta_chip"
                android:paddingHorizontal="5dp"
                android:paddingVertical="1dp"
                android:text="@string/word_detail_common"
                android:textColor="?attr/ptTextMuted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvItemFreq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="?attr/ptTextHint"
                android:textSize="10sp"
                android:visibility="gone" />

        </com.playtranslate.ui.FlowLayout>

        <TextView
            android:id="@+id/tvItemMeaning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/ptTextMuted"
            android:textSize="13sp" />

    </LinearLayout>

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="12dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="?attr/ptTextMuted"
        android:importantForAccessibility="no" />

</LinearLayout>
