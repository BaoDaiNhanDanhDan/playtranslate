<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/ptBg">

    <!-- Toolbar: [Edit]  title  [+] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnEditRegion"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:text="@string/label_edit"
            android:textColor="?attr/ptAccent"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tvRegionPickerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/label_select_region"
                android:textColor="?attr/ptText"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Pill segmented control for per-display region selection
                 (built programmatically by RegionPickerSheet via buildPillToggle). -->
            <FrameLayout
                android:id="@+id/displaySegmentedControl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginHorizontal="4dp"
                android:visibility="gone" />

        </FrameLayout>

        <Button
            android:id="@+id/btnAddRegion"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:text="@string/region_picker_add_glyph"
            android:textColor="?attr/ptAccent"
            android:textSize="22sp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <!-- Region list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/regionRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="@dimen/pt_section_h_padding"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:clipToPadding="false"
        android:clipChildren="false" />

</LinearLayout>
