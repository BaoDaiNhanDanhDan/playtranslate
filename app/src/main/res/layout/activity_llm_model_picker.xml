<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen model picker for the LLM backends. Title is set
     programmatically from LlmBackendConfig.titleStringRes (so one
     layout serves OpenAI / Gemini / future providers). Toolbar uses
     ic_arrow_back to match LanguageSetupActivity / AnkiDeckPickerDialog,
     which is the visual language for "back navigates without saving" —
     row taps in this picker write the chosen model directly to prefs
     and finish(), so the back button itself only matters for the
     no-selection case. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/ptSurface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/ptText"
        app:titleTextColor="?attr/ptText" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/modelListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
