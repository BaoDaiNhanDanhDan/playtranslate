<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/ptSurface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/ptText"
        app:title="@string/settings_cell_translation_services"
        app:titleTextColor="?attr/ptText" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/pt_section_h_padding"
            android:paddingTop="4dp"
            android:paddingBottom="20dp">

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- ONLINE TRANSLATIONS                                   -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerOnlineTranslations" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/settings_row_backend"
                        android:id="@+id/rowBackendGemini" />

                    <!-- "Model" sub-cell under the Gemini row. Visible only
                         when the backend is enabled; the outer LinearLayout
                         exists as a visibility-toggle wrapper so the row
                         includes can stay inflated normally. -->
                    <LinearLayout
                        android:id="@+id/sectionBackendGeminiModel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <include layout="@layout/settings_row_value"
                            android:id="@+id/rowBackendGeminiModel" />
                    </LinearLayout>

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_backend"
                        android:id="@+id/rowBackendOpenai" />

                    <LinearLayout
                        android:id="@+id/sectionBackendOpenaiModel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <include layout="@layout/settings_row_value"
                            android:id="@+id/rowBackendOpenaiModel" />
                    </LinearLayout>

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_backend"
                        android:id="@+id/rowBackendDeepseek" />

                    <LinearLayout
                        android:id="@+id/sectionBackendDeepseekModel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <include layout="@layout/settings_row_value"
                            android:id="@+id/rowBackendDeepseekModel" />
                    </LinearLayout>

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_backend"
                        android:id="@+id/rowBackendDeepl" />

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_backend"
                        android:id="@+id/rowBackendLingva" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_word_tatoeba_attribution"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/tr_service_order_footer"
                        android:textColor="?attr/ptTextHint"
                        android:textSize="11sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- OFFLINE TRANSLATIONS                                  -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerOfflineTranslations" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Premium-quality manual-lookup tier (replaces the
                         legacy TranslateGemma). -->
                    <include layout="@layout/settings_row_backend_offline"
                        android:id="@+id/rowBackendGemmaE2bMnn" />

                    <!-- Divider above the Hunyuan-MT 1.5 row (translation-
                         specialist tier). The HyMt row is hidden entirely
                         (visibility=GONE) when RegionPolicy.isHunyuanRestricted
                         returns true (EU/UK/SK) OR when the catalog entry's
                         size/sha256 are still placeholders; see
                         SettingsRenderer.wireHyMtBackendRow. -->
                    <include layout="@layout/settings_row_divider"
                        android:id="@+id/dividerBackendHyMt" />

                    <include layout="@layout/settings_row_backend_offline"
                        android:id="@+id/rowBackendHyMt" />

                    <!-- Qwen 3.5 2B (fast tier; replaces the deprecated Qwen 2.5). -->
                    <include layout="@layout/settings_row_divider"
                        android:id="@+id/dividerBackendQwen35Mnn2b" />

                    <include layout="@layout/settings_row_backend_offline"
                        android:id="@+id/rowBackendQwen35Mnn2b" />

                    <!-- Divider above the deprecated Qwen 2.5 MNN tier (the row
                         and this divider hide unless the model is installed —
                         see SettingsRenderer deprecation gating). -->
                    <include layout="@layout/settings_row_divider"
                        android:id="@+id/dividerBackendQwenMnn" />

                    <include layout="@layout/settings_row_backend_offline"
                        android:id="@+id/rowBackendQwenMnn" />

                    <include layout="@layout/settings_row_divider"
                        android:id="@+id/dividerBackendBergamot" />

                    <include layout="@layout/settings_row_backend_offline"
                        android:id="@+id/rowBackendBergamot" />

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_backend_offline"
                        android:id="@+id/rowBackendMlkit" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_word_tatoeba_attribution"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/tr_service_offline_footer"
                        android:textColor="?attr/ptTextHint"
                        android:textSize="11sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
