<?xml version="1.0" encoding="utf-8"?>
<!-- Row for the TTS voice picker: voice name + API info on the left, a
     trailing accent checkmark on the currently-selected voice. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/pt_row_min_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/pt_row_h_padding"
    android:paddingEnd="@dimen/pt_row_h_padding"
    android:paddingVertical="@dimen/pt_row_v_padding"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="16dp">

        <TextView
            android:id="@+id/tvRowTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.PT.RowTitle" />

        <TextView
            android:id="@+id/tvRowSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            style="@style/Text.PT.RowSubtitle" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivCheck"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_check"
        app:tint="?attr/ptAccent"
        android:visibility="gone"
        android:importantForAccessibility="no" />

</LinearLayout>
