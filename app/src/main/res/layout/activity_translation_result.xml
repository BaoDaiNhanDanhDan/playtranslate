<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Top bar: back button on the left, optional pill toggle in the
         middle (drag-flow word context). The fragment carries its own
         bottom-bar Anki button, so we don't need a duplicate here.
         48dp gives the 32dp pill room to breathe; the 44dp back button
         stays vertically centered. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_translation_result_back"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/ptTextMuted" />

        <FrameLayout
            android:id="@+id/segmentedTabContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:paddingHorizontal="12dp" />

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/resultFragmentContainer"
            android:name="com.playtranslate.ui.TranslationResultFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:id="@+id/wordDetailContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Edit overlay: covers the result/word area when editing the
             original text. Opaque ?attr/ptBg so it hides the result
             beneath; the top bar (back button) stays visible above it.
             Mirrors the editOverlay in activity_main.xml. -->
        <LinearLayout
            android:id="@+id/editOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="?attr/ptBg"
            android:visibility="gone">

            <!-- Editable text fills entire overlay; keyboard shows "Go" action -->
            <EditText
                android:id="@+id/etEditOriginal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="top|start"
                android:paddingHorizontal="14dp"
                android:paddingTop="12dp"
                android:textSize="24sp"
                android:textColor="?attr/ptText"
                android:lineSpacingMultiplier="1.5"
                android:background="@null"
                android:inputType="textMultiLine"
                android:imeOptions="actionGo"
                android:hint="@string/cd_edit_original"
                android:importantForAutofill="no"
                android:scrollbars="vertical" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
